{
	"info": {
		"name": "NG-Fields API",
		"description": "Collection pour tester l'API Spring Boot + Keycloak",
		"schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
	},
	"variable": [
		{
			"key": "base_url",
			"value": "http://localhost:8081"
		},
		{
			"key": "kc_url",
			"value": "http://localhost:8080"
		},
		{
			"key": "client_secret",
			"value": "**********"
		},
		{
			"key": "access_token",
			"value": ""
		}
	],
	"item": [
		{
			"name": "1. Token client_credentials",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var json = pm.response.json();",
							"pm.collectionVariables.set(\"access_token\", json.access_token);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{ "key": "client_id", "value": "ng-fields-backend" },
						{ "key": "client_secret", "value": "{{client_secret}}" },
						{ "key": "grant_type", "value": "client_credentials" }
					]
				},
				"url": {
					"raw": "{{kc_url}}/realms/ng-fields/protocol/openid-connect/token",
					"host": ["{{kc_url}}"],
					"path": ["realms", "ng-fields", "protocol", "openid-connect", "token"]
				}
			}
		},
		{
			"name": "2. Token password (admin)",
			"event": [
				{
					"listen": "test",
					"script": {
						"exec": [
							"var json = pm.response.json();",
							"pm.collectionVariables.set(\"access_token\", json.access_token);"
						]
					}
				}
			],
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "urlencoded",
					"urlencoded": [
						{ "key": "client_id", "value": "ng-fields-backend" },
						{ "key": "client_secret", "value": "{{client_secret}}" },
						{ "key": "grant_type", "value": "password" },
						{ "key": "username", "value": "admin" },
						{ "key": "password", "value": "Admin123!" }
					]
				},
				"url": {
					"raw": "{{kc_url}}/realms/ng-fields/protocol/openid-connect/token",
					"host": ["{{kc_url}}"],
					"path": ["realms", "ng-fields", "protocol", "openid-connect", "token"]
				}
			}
		},
		{
			"name": "3. Health check (public)",
			"request": {
				"method": "GET",
				"header": [],
				"url": {
					"raw": "{{base_url}}/api/public/health",
					"host": ["{{base_url}}"],
					"path": ["api", "public", "health"]
				}
			}
		},
		{
			"name": "4. Creer user ADMIN",
			"request": {
				"method": "POST",
				"header": [
					{
						"key": "Authorization",
						"value": "Bearer {{access_token}}"
					}
				],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"nouveluser\",\n  \"email\": \"nouvel@test.com\",\n  \"firstName\": \"Nouvel\",\n  \"lastName\": \"User\",\n  \"password\": \"MonPass123!\",\n  \"role\": \"MANAGER\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/admin/users",
					"host": ["{{base_url}}"],
					"path": ["api", "admin", "users"]
				}
			}
		},
		{
			"name": "5. Inscription publique",
			"request": {
				"method": "POST",
				"header": [],
				"body": {
					"mode": "raw",
					"raw": "{\n  \"username\": \"client_dupont\",\n  \"email\": \"dupont@example.com\",\n  \"firstName\": \"Jean\",\n  \"lastName\": \"Dupont\",\n  \"password\": \"MonMotDePasse123!\"\n}"
				},
				"url": {
					"raw": "{{base_url}}/api/public/register",
					"host": ["{{base_url}}"],
					"path": ["api", "public", "register"]
				}
			}
		}
	]
}
