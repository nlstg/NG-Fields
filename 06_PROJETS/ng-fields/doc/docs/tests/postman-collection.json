            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"inscrit_test\",\n  \"email\": \"inscrit@test.tg\",\n  \"firstName\": \"Inscrit\",\n  \"lastName\": \"Test\",\n  \"password\": \"InscritPass123!\",\n  \"role\": \"CLIENT_PORTAL\"\n}"
        },
        "url": "{{base_url}}/api/public/register"
