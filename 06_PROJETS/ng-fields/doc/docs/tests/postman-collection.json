    {
      "name": "14. Créer un client (ADMIN)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Client créé\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.companyName).to.eql(\"NG-STARs SARL\");",
              "    pm.expect(json.active).to.be.true;",
              "    pm.expect(json.id).to.not.be.empty;",
              "});",
              "",
              "var json = pm.response.json();",
              "pm.collectionVariables.set(\"testClientId\", json.id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{adminToken}}"
          }
