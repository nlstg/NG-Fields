    {
      "name": "1. Health check",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"API is UP\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.status).to.eql(\"UP\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "url": "{{base_url}}/api/public/health"
      }
    },
