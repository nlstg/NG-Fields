    {
      "name": "7. Inscription publique",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status is 201\", function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "pm.test(\"Compte créé avec succès\", function () {",
              "    var json = pm.response.json();",
              "    pm.expect(json.message).to.include(\"succès\");",
              "    pm.expect(json.user.username).to.eql(\"inscrit_test\");",
              "    pm.expect(json.user.role).to.eql(\"CLIENT_PORTAL\");",
              "    pm.expect(json.user.enabled).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
