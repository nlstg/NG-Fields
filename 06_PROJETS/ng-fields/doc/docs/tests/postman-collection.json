        "body": {
          "mode": "raw",
          "raw": "{\n  \"companyName\": \"NG-STARs SARL\",\n  \"email\": \"contact@ngstars.tg\",\n  \"phone\": \"+22890000000\",\n  \"address\": \"Lomé, Togo\",\n  \"contactName\": \"Jean Dupont\",\n  \"contactPhone\": \"+22890000001\"\n}"
